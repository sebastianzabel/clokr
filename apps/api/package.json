{
  "name": "@clokr/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --env-file=.env watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "pretest": "sh -c 'set -a; . ./.env.test; set +a; DATABASE_URL=$TEST_DATABASE_URL pnpm --filter @clokr/db exec prisma db push'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clokr/db": "workspace:*",
    "@clokr/types": "workspace:*",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/adapter-pg": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "date-fns-tz": "^3.2.0",
    "fastify": "^5.8.5",
    "iconv-lite": "^0.7.2",
    "minio": "^8.0.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "fastify-plugin": "^5.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
