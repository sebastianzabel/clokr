{
  "name": "salon-timetrack",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @salon/db migrate",
    "db:generate": "pnpm --filter @salon/db generate",
    "db:studio": "pnpm --filter @salon/db studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^6.0.0",
    "@types/node": "^25.0.0"
  },
  "pnpm": {
    "overrides": {
      "@fastify/swagger>esbuild": "0.21.5"
    }
  }
}
