generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANT
// ─────────────────────────────────────────────

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  federalState FederalState @default(NIEDERSACHSEN)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt    @db.Timestamptz

  employees         Employee[]
  leaveTypes        LeaveType[]
  publicHolidays    PublicHoliday[]
  config            TenantConfig?
  companyShutdowns  CompanyShutdown[]
  shiftTemplates    ShiftTemplate[]
  terminalApiKeys   TerminalApiKey[]
  specialLeaveRules SpecialLeaveRule[]
}

// ─────────────────────────────────────────────
// MANDANTEN-KONFIGURATION (globale Arbeitszeitvorgaben)
// ─────────────────────────────────────────────

model TenantConfig {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  // Standard-Wochenstunden (Vorlage für neue Mitarbeiter)
  defaultWeeklyHours   Decimal  @db.Decimal(5, 2)  @default(40)
  defaultMondayHours   Decimal  @db.Decimal(4, 2)  @default(8)
  defaultTuesdayHours  Decimal  @db.Decimal(4, 2)  @default(8)
  defaultWednesdayHours Decimal @db.Decimal(4, 2)  @default(8)
  defaultThursdayHours Decimal  @db.Decimal(4, 2)  @default(8)
  defaultFridayHours   Decimal  @db.Decimal(4, 2)  @default(8)
  defaultSaturdayHours Decimal  @db.Decimal(4, 2)  @default(0)
  defaultSundayHours   Decimal  @db.Decimal(4, 2)  @default(0)
  // Überstunden
  overtimeThreshold    Decimal  @db.Decimal(5, 2)  @default(60)
  allowOvertimePayout  Boolean  @default(false)
  // Urlaubsanspruch (Basis 5-Tage-Woche)
  defaultVacationDays  Decimal  @db.Decimal(5, 2)  @default(30)
  // Resturlaub-Verfall: Tag und Monat im Folgejahr (z.B. 31. März = day=31, month=3)
  carryOverDeadlineDay   Int    @default(31)
  carryOverDeadlineMonth Int    @default(3)
  // E-Mail / SMTP
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPassword  String?
  smtpFromEmail String?
  smtpFromName  String?
  smtpSecure    Boolean  @default(false)
  // Sicherheit
  twoFaEnabled           Boolean  @default(false)
  // Passwort-Richtlinie (BSI TR-02102-1)
  passwordMinLength      Int      @default(12)
  passwordRequireUpper   Boolean  @default(true)
  passwordRequireLower   Boolean  @default(true)
  passwordRequireDigit   Boolean  @default(true)
  passwordRequireSpecial Boolean  @default(true)
  // Zeitzone (IANA)
  timezone      String   @default("Europe/Berlin")
  // Phorest-Integration
  phorestBusinessId String?
  phorestBranchId   String?
  phorestUsername   String?
  phorestPassword   String?
  phorestBaseUrl    String?  @default("https://api.phorest.com/third-party-api-server")
  phorestAutoSync   Boolean  @default(false)
  phorestSyncCron   String   @default("0 3 * * *") // Default: täglich 03:00
  // Compliance
  arbzgEnabled           Boolean @default(true)  // ArbZG-Verstöße anzeigen
  // Heiligabend / Silvester: NORMAL | HALF_DAY | FULL_DAY_OFF
  christmasEveRule       String  @default("NORMAL")
  newYearsEveRule        String  @default("NORMAL")
  // Abwesenheits-Konfiguration
  vacationLeadTimeDays   Int     @default(0)    // Min. Tage im Voraus für Urlaubsanträge (0 = keine)
  vacationMaxAdvanceMonths Int   @default(0)    // Max. Monate im Voraus für Urlaub (0 = unbegrenzt)
  halfDayAllowed         Boolean @default(true) // Halbe Tage erlaubt
  sickSelfReport         Boolean @default(true) // MA dürfen Krankmeldung selbst eintragen
  sickNoteRequiredAfterDays Int  @default(3)    // AU-Pflicht nach X Krankheitstagen
  // Teilzeit-Urlaub
  autoCalcPartTimeVacation Boolean @default(true) // Automatische Pro-Rata Berechnung
  fullTimeWorkDaysPerWeek  Int    @default(5)     // Referenz für Vollzeit (5 oder 6)

  // E-Mail-Benachrichtigungen
  emailNotificationsEnabled  Boolean @default(false) // Master switch
  emailOnLeaveRequest        Boolean @default(true)  // Neuer Urlaubsantrag
  emailOnLeaveDecision       Boolean @default(true)  // Urlaub genehmigt/abgelehnt
  emailOnOvertimeWarning     Boolean @default(false) // Überstunden-Schwellwert
  emailOnMissingEntries      Boolean @default(false) // Fehlende Zeiteinträge
  emailOnClockOutReminder    Boolean @default(false) // Vergessene Stempelung
  emailOnMonthClose          Boolean @default(true)  // Monatsabschluss
  // Automatische Erinnerungen
  reminderPendingLeaveHours    Int     @default(48)   // Manager erinnern nach X Stunden ohne Reaktion
  reminderUpcomingAbsenceDays  Int     @default(3)    // MA erinnern X Tage vor Abwesenheit
  reminderPendingLeaveEnabled  Boolean @default(true)
  reminderUpcomingAbsenceEnabled Boolean @default(true)
  // Benachrichtigungen
  clockOutReminderHours  Int @default(10)  // Stunden nach denen an offene Stempelung erinnert wird
  missingEntriesDays     Int @default(7)   // Tage ohne Einträge bevor erinnert wird
  autoDeleteOpenHours    Int @default(14)  // Stunden nach denen offene Einträge auto-gelöscht werden (0 = deaktiviert)
  // Pausen-Slots
  autoBreakEnabled       Boolean @default(false)
  defaultBreakStart      String? @db.VarChar(5)  // e.g. "12:00"
  // Überstunden-Jahresübertrag
  overtimeCarryOverMode  String  @default("FULL") // FULL | CAPPED | RESET
  overtimeCarryOverCap   Int?    // Max. Übertrag in Minuten (nur bei CAPPED)
  // Max. Minusstunden (null = unbegrenzt, Wert in Minuten)
  maxNegativeBalanceMinutes Int?
  // Aufbewahrungsfrist in Jahren (Minimum 2, Default 10)
  dataRetentionYears     Int     @default(10)
  createdAt            DateTime @default(now()) @db.Timestamptz
  updatedAt            DateTime @updatedAt      @db.Timestamptz

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(EMPLOYEE)
  isActive           Boolean    @default(true)
  emailNotifications Boolean    @default(true) // Per-user email opt-out
  lastLoginAt        DateTime?  @db.Timestamptz
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt      @db.Timestamptz

  employee      Employee?
  refreshTokens RefreshToken[]
  otpTokens     OtpToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime  @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id        String    @id @default(uuid())
  userId    String
  code      String                          // 6-stellig, bcrypt-gehasht
  expiresAt DateTime  @db.Timestamptz      // now + 10 min
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id          String    @id @default(uuid())
  token       String    @unique
  employeeId  String
  email       String
  expiresAt   DateTime  @db.Timestamptz
  acceptedAt  DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// MITARBEITER
// ─────────────────────────────────────────────

model Employee {
  id               String   @id @default(uuid())
  tenantId         String
  userId           String   @unique
  employeeNumber   String
  firstName        String
  lastName         String
  nfcCardId        String?  @unique  // NFC Karten-ID
  hireDate         DateTime @db.Timestamptz
  exitDate         DateTime? @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt      @db.Timestamptz

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workSchedules    WorkSchedule[]
  overtimeAccount  OvertimeAccount?
  saldoSnapshots   SaldoSnapshot[]
  timeEntries      TimeEntry[]
  leaveEntitlements LeaveEntitlement[]
  leaveRequests    LeaveRequest[]
  absences              Absence[]
  overtimePlans         OvertimePlan[]
  invitations           Invitation[]
  shutdownExceptions    CompanyShutdownException[]
  shifts                Shift[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// ARBEITSZEITMODELL
// ─────────────────────────────────────────────

model WorkSchedule {
  id                    String       @id @default(uuid())
  employeeId            String
  type                  ScheduleType @default(FIXED_WEEKLY)
  weeklyHours           Decimal      @db.Decimal(5, 2)  // z.B. 40.00
  monthlyHours          Decimal?     @db.Decimal(5, 2)  // z.B. 15.00 für Minijobber
  mondayHours           Decimal  @db.Decimal(4, 2)  @default(8)
  tuesdayHours          Decimal  @db.Decimal(4, 2)  @default(8)
  wednesdayHours        Decimal  @db.Decimal(4, 2)  @default(8)
  thursdayHours         Decimal  @db.Decimal(4, 2)  @default(8)
  fridayHours           Decimal  @db.Decimal(4, 2)  @default(8)
  saturdayHours         Decimal  @db.Decimal(4, 2)  @default(0)
  sundayHours           Decimal  @db.Decimal(4, 2)  @default(0)
  overtimeThreshold     Decimal  @db.Decimal(5, 2)  @default(60)  // Alert ab X Stunden
  allowOvertimePayout   Boolean  @default(false)
  maxNegativeBalanceMinutes Int? // Pro-MA Override (null = Tenant-Default)
  validFrom             DateTime @db.Timestamptz
  createdAt             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @updatedAt      @db.Timestamptz

  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, validFrom])
}

// ─────────────────────────────────────────────
// ZEITERFASSUNG
// ─────────────────────────────────────────────

model TimeEntry {
  id           String          @id @default(uuid())
  employeeId   String
  date         DateTime        @db.Date
  startTime    DateTime        @db.Timestamptz
  endTime      DateTime?       @db.Timestamptz
  breakMinutes Int             @default(0)
  type         TimeEntryType   @default(WORK)
  source       TimeEntrySource @default(MANUAL)
  note         String?
  isLocked     Boolean         @default(false)  // nach Monatsabschluss gesperrt
  lockedAt     DateTime?       @db.Timestamptz
  isInvalid    Boolean         @default(false) // automatisch invalidiert (z.B. kein Ausstempeln)
  invalidReason String?                        // Grund der Invalidierung
  deletedAt    DateTime?       @db.Timestamptz // soft delete
  createdAt    DateTime        @default(now()) @db.Timestamptz
  updatedAt    DateTime        @updatedAt      @db.Timestamptz
  createdBy    String?         // userId wer es angelegt hat

  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  breaks       Break[]

  @@index([employeeId, date])
  @@index([date])
}

model Break {
  id          String    @id @default(uuid())
  timeEntryId String
  startTime   DateTime  @db.Timestamptz
  endTime     DateTime  @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz

  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([timeEntryId])
}

// ─────────────────────────────────────────────
// SALDO-SNAPSHOTS (Monatsabschluss / Jahresübertrag)
// ─────────────────────────────────────────────

model SaldoSnapshot {
  id              String             @id @default(uuid())
  employeeId      String
  periodType      SaldoPeriodType
  periodStart     DateTime           @db.Date
  periodEnd       DateTime           @db.Date
  workedMinutes   Int                // Ist-Arbeitszeit im Zeitraum
  expectedMinutes Int                // Soll-Arbeitszeit im Zeitraum
  balanceMinutes  Int                // Differenz (worked - expected)
  carryOver       Int                // Kumulierter Übertrag bis periodEnd
  closedAt        DateTime           @db.Timestamptz
  closedBy        String?            // userId wer abgeschlossen hat (null = SYSTEM)
  note            String?

  employee        Employee           @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, periodType, periodStart])
  @@index([employeeId])
  @@index([employeeId, periodType])
}

enum SaldoPeriodType {
  MONTHLY
  YEARLY
}

// ─────────────────────────────────────────────
// ÜBERSTUNDENKONTO
// ─────────────────────────────────────────────

model OvertimeAccount {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  balanceHours Decimal  @db.Decimal(7, 2) @default(0)  // aktueller Saldo
  updatedAt    DateTime @updatedAt @db.Timestamptz

  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  transactions OvertimeTransaction[]
}

model OvertimeTransaction {
  id                String              @id @default(uuid())
  overtimeAccountId String
  hours             Decimal             @db.Decimal(7, 2)  // positiv = Überstunden, negativ = Abbau
  type              OvertimeTransactionType
  description       String?
  referenceMonth    String?             // "2024-03" für Monatsabschluss
  createdAt         DateTime            @default(now()) @db.Timestamptz
  createdBy         String?

  overtimeAccount   OvertimeAccount     @relation(fields: [overtimeAccountId], references: [id], onDelete: Cascade)

  @@index([overtimeAccountId])
}

model OvertimePlan {
  id           String           @id @default(uuid())
  employeeId   String
  hoursToReduce Decimal         @db.Decimal(7, 2)
  deadline     DateTime         @db.Timestamptz
  status       OvertimePlanStatus @default(ACTIVE)
  note         String?
  createdAt    DateTime         @default(now()) @db.Timestamptz
  createdBy    String

  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ─────────────────────────────────────────────
// URLAUB
// ─────────────────────────────────────────────

model LeaveType {
  id               String   @id @default(uuid())
  tenantId         String
  name             String   // "Urlaub", "Sonderurlaub", etc.
  isPaid           Boolean  @default(true)
  requiresApproval Boolean  @default(true)
  color            String   @default("#3B82F6")
  allowHalfDay     Boolean  @default(true)   // Can this type be requested as half-day?
  maxDaysPerYear   Int?                       // Optional annual limit per employee
  leadTimeDays     Int?                       // Per-type override for lead time (null = use global)
  createdAt        DateTime @default(now()) @db.Timestamptz

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entitlements LeaveEntitlement[]
  requests     LeaveRequest[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LeaveEntitlement {
  id                String   @id @default(uuid())
  employeeId        String
  leaveTypeId       String
  year              Int
  totalDays         Decimal  @db.Decimal(5, 2)
  usedDays          Decimal  @db.Decimal(5, 2) @default(0)
  carriedOverDays   Decimal  @db.Decimal(5, 2) @default(0)  // Resturlaub Vorjahr
  carryOverDeadline DateTime? @db.Timestamptz // bis wann Resturlaub genommen werden muss
  isAutoCalculated  Boolean  @default(false)  // Was this entitlement auto-calculated for part-time?
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt      @db.Timestamptz

  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType         LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
}

model SpecialLeaveRule {
  id            String   @id @default(uuid())
  tenantId      String
  name          String   // e.g. "Hochzeit", "Geburt eines Kindes"
  reason        String?  // Description / display text
  defaultDays   Decimal  @db.Decimal(4, 2) @default(1) // Default entitlement days
  isStatutory   Boolean  @default(false) // § 616 BGB (cannot be deleted, only deactivated)
  requiresProof Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt      @db.Timestamptz

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LeaveRequest {
  id           String             @id @default(uuid())
  employeeId   String
  leaveTypeId  String
  specialLeaveRuleId String?     // For SPECIAL type: which rule applies
  startDate    DateTime           @db.Date
  endDate      DateTime           @db.Date
  days         Decimal            @db.Decimal(5, 2)
  halfDay      Boolean            @default(false)
  status       LeaveRequestStatus @default(PENDING)
  note         String?
  reviewedBy   String?
  reviewedAt   DateTime?          @db.Timestamptz
  reviewNote   String?
  // Attest (nur für SICK / SICK_CHILD)
  attestPresent    Boolean   @default(false)
  attestValidFrom  DateTime? @db.Date
  attestValidTo    DateTime? @db.Date
  deletedAt    DateTime?          @db.Timestamptz // soft delete
  createdAt    DateTime           @default(now()) @db.Timestamptz
  updatedAt    DateTime           @updatedAt      @db.Timestamptz

  employee         Employee           @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType        LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  specialLeaveRule SpecialLeaveRule?  @relation(fields: [specialLeaveRuleId], references: [id])

  @@index([employeeId])
  @@index([employeeId, status])
  @@index([leaveTypeId])
}

// ─────────────────────────────────────────────
// ABWESENHEITEN
// ─────────────────────────────────────────────

model Absence {
  id           String       @id @default(uuid())
  employeeId   String
  type         AbsenceType
  startDate    DateTime     @db.Date
  endDate      DateTime     @db.Date
  days         Decimal      @db.Decimal(5, 2)
  note         String?
  documentPath String?      // Pfad zur AU-Bescheinigung (MinIO)
  deletedAt    DateTime?    @db.Timestamptz // soft delete
  createdAt    DateTime     @default(now()) @db.Timestamptz
  createdBy    String

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
}

// ─────────────────────────────────────────────
// FEIERTAGE
// ─────────────────────────────────────────────

model PublicHoliday {
  id           String       @id @default(uuid())
  tenantId     String
  date         DateTime     @db.Date
  name         String
  federalState FederalState
  year         Int

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, year])
}

// ─────────────────────────────────────────────
// AUDIT LOG (DSGVO)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  entity     String   // "TimeEntry", "LeaveRequest", etc.
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now()) @db.Timestamptz

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// NFC TERMINAL API KEYS
// ─────────────────────────────────────────────

model TerminalApiKey {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum FederalState {
  NIEDERSACHSEN
  BAYERN
  BERLIN
  BRANDENBURG
  BREMEN
  HAMBURG
  HESSEN
  MECKLENBURG_VORPOMMERN
  NORDRHEIN_WESTFALEN
  RHEINLAND_PFALZ
  SAARLAND
  SACHSEN
  SACHSEN_ANHALT
  SCHLESWIG_HOLSTEIN
  THUERINGEN
  BADEN_WUERTTEMBERG
}

enum TimeEntryType {
  WORK
  OVERTIME
  PUBLIC_HOLIDAY
}

enum TimeEntrySource {
  NFC
  MOBILE
  MANUAL
  CORRECTION
}

enum OvertimeTransactionType {
  ACCRUAL       // Überstunden angesammelt (Monatsabschluss)
  REDUCTION     // Abbau (Freizeit genommen)
  PAYOUT        // Ausbezahlt
  CORRECTION    // Manuelle Korrektur
}

enum OvertimePlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  CANCELLATION_REQUESTED
}

enum AbsenceType {
  SICK              // Krankheit
  SICK_CHILD        // Kindkrank
  SPECIAL_LEAVE     // Sonderurlaub
  UNPAID_LEAVE      // Unbezahlter Urlaub
  MATERNITY         // Mutterschutz
  PARENTAL          // Elternzeit
  OTHER
}

enum ScheduleType {
  FIXED_WEEKLY      // Feste Wochentage (z.B. Mo-Fr 8h)
  MONTHLY_HOURS     // Monatsstunden-Budget (z.B. 15h/Monat für Minijobber)
}

// ─────────────────────────────────────────────
// BETRIEBSURLAUB
// ─────────────────────────────────────────────

model CompanyShutdown {
  id                  String   @id @default(uuid())
  tenantId            String
  name                String                         // z.B. "Weihnachtsschließung 2025"
  startDate           DateTime @db.Date
  endDate             DateTime @db.Date
  deductsFromVacation Boolean  @default(true)        // zieht vom Urlaubskonto ab
  notes               String?
  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @updatedAt      @db.Timestamptz

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exceptions          CompanyShutdownException[]

  @@index([tenantId])
  @@index([tenantId, startDate])
}

/// Mitarbeiter, die vom Betriebsurlaub AUSGENOMMEN sind
model CompanyShutdownException {
  id           String   @id @default(uuid())
  shutdownId   String
  employeeId   String
  reason       String?
  createdAt    DateTime @default(now()) @db.Timestamptz

  shutdown     CompanyShutdown @relation(fields: [shutdownId], references: [id], onDelete: Cascade)
  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([shutdownId, employeeId])
}

// ─────────────────────────────────────────────
// BENACHRICHTIGUNGEN
// ─────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // LEAVE_REQUEST, LEAVE_APPROVED, LEAVE_REJECTED, OVERTIME_WARNING, MISSING_ENTRY
  title      String
  message    String
  link       String?  // e.g. "/leave" or "/admin/vacation"
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// SCHICHTPLANUNG
// ─────────────────────────────────────────────

model ShiftTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   // e.g. "Frühschicht", "Spätschicht", "Nachtschicht"
  startTime String   // "06:00"
  endTime   String   // "14:00"
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now()) @db.Timestamptz

  shifts    Shift[]

  @@index([tenantId])
}

model Shift {
  id           String         @id @default(uuid())
  employeeId   String
  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId   String?
  template     ShiftTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  date         DateTime       @db.Date
  startTime    String         // "06:00"
  endTime      String         // "14:00"
  label        String?        // Custom label or template name
  note         String?
  createdAt    DateTime       @default(now()) @db.Timestamptz
  createdBy    String?

  @@index([employeeId, date])
  @@index([date])
}
