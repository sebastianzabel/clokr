# Database
DATABASE_URL="postgresql://clokr:password@localhost:5432/clokr"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3000
API_HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3 (für Exporte)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="clokr"

# Encryption key for sensitive DB fields (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-generate-a-random-64-char-hex-string!!"
